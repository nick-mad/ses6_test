# Copy this file to .env and adjust values for local development
# .env is loaded automatically by docker-compose

# individual variables (used when DATABASE_URL is not set)
# DB_ADAPTER=pgsql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=release_notification
# DB_USER=postgres
# DB_PASS=postgres

# GitHub API token (required for release scanning)
GITHUB_TOKEN=

# Mail settings
MAIL_DRIVER=log
MAIL_DSN=null://default
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME="Release Notifier"
MAIL_BASE_URL=http://localhost:8080
